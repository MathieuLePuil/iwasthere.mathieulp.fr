{% extends 'base.html.twig' %}
{% import 'components/_macros.html.twig' as m %}
{% import 'components/_filters.html.twig' as f %}

{% block title %}Sport — IWasThere{% endblock %}

{% block body %}
<div class="px-4 py-5">

    <div class="flex items-center justify-between mb-4">
        <h1 class="text-2xl font-semibold tracking-tight" style="color: var(--fg-1); letter-spacing: -0.01em">Sport</h1>
        <div class="flex items-center gap-2">
            <button type="button" class="iwt-icon-btn" aria-label="Configurer mes équipes porte-bonheur"
                    onclick="document.getElementById('team-config').showModal()">
                {# Blason : « mon équipe », plutôt qu'une roue crantée de réglages #}
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 3l7 2.5V11c0 4.5-3 7.6-7 9-4-1.4-7-4.5-7-9V5.5L12 3z"/>
                </svg>
            </button>
            <a href="{{ path('app_event_new', {category: 'sport'}) }}"
               class="iwt-icon-btn text-lg font-bold leading-none" style="color: var(--positive)">+</a>
        </div>
    </div>

    {# Modal — équipes porte-bonheur, une par sport collectif, ouverte par le blason ci-dessus #}
    {% set sport_labels = {'football': '⚽ Football', 'rugby': '🏉 Rugby'} %}
    <dialog id="team-config" class="iwt-dialog">
        <form method="post" action="{{ path('app_sport_favorite_team') }}">
            <h2 class="font-semibold text-lg mb-1" style="color: var(--fg-1)">Mes équipes 🍀</h2>
            <p class="text-sm mb-4" style="color: var(--fg-3)">
                Ton porte-bonheur : le taux de victoires de tes équipes quand tu es au stade.
                Le nom doit correspondre à celui que tu saisis dans tes matchs.
            </p>
            <div class="space-y-3 mb-4">
                {% for sport, label in sport_labels %}
                <div>
                    <label class="block text-sm font-medium mb-1" style="color: var(--fg-3)">{{ label }}</label>
                    <input type="text" name="favorite_team[{{ sport }}]" value="{{ app.user.getFavoriteTeam(sport) }}"
                           class="input-field" maxlength="100" placeholder="Nom de l'équipe">
                </div>
                {% endfor %}
            </div>
            <div class="flex gap-2">
                <button type="button" class="btn-secondary flex-1 py-2.5"
                        onclick="this.closest('dialog').close()">Annuler</button>
                <button type="submit" class="btn-primary flex-1 py-2.5">Enregistrer</button>
            </div>
        </form>
    </dialog>

    {{ f.bar(
        route:          'app_sport',
        query:          app.request.query.all,
        tab:            tab,
        past_count:     past_count,
        upcoming_count: upcoming_count,
        types: [
            {value: '',         label: 'Tous'},
            {value: 'football', label: '⚽ Football'},
            {value: 'rugby',    label: '🏉 Rugby'},
            {value: 'tennis',   label: '🎾 Tennis'}
        ],
        active_type: filter_type,
        years:       years,
        active_year: filter_year,
        sorts: [
            {value: 'date',   label: 'Plus récents'},
            {value: 'rating', label: 'Mieux notés'}
        ],
        active_sort: sort_by,
        count:       participations|length
    ) }}

    {# Events list #}
    {% if participations|length == 0 %}
        {{ m.empty_state(
            '🏟️',
            (filter_type or filter_year) ? 'Aucun match avec ces filtres' : 'Aucun événement sportif',
            (filter_type or filter_year)
                ? 'Essaie d\'élargir tes filtres.'
                : (tab == 'upcoming' ? 'Ajoute un match à venir !' : 'Commence à archiver tes matchs'),
            (filter_type or filter_year) ? path('app_sport', {tab: tab}) : path('app_event_new', {category: 'sport'}),
            (filter_type or filter_year) ? 'Réinitialiser les filtres' : '+ Ajouter un match'
        ) }}
    {# Grouped by year for past events sorted by date #}
    {% elseif tab == 'past' and sort_by == 'date' %}
        {% set current_year = null %}
        {% for p in participations %}
            {% set event_year = p.event.date|date('Y') %}
            {% if event_year != current_year %}
                {% if current_year is not null %}</div>{% endif %}
                <div class="iwt-year"><span class="iwt-year-num">{{ event_year }}</span></div>
                <div class="card" style="padding: 0; overflow: hidden; margin-bottom: 16px">
                {% set current_year = event_year %}
            {% endif %}
            {{ _self.match_row(p) }}
            {% if loop.last %}</div>{% endif %}
        {% endfor %}
    {% else %}
        <div class="card" style="padding: 0; overflow: hidden">
            {% for p in participations %}{{ _self.match_row(p) }}{% endfor %}
        </div>
    {% endif %}

</div>

{# Une ligne de match — réutilisée en liste simple et en groupes par année #}
{% macro match_row(p) %}
    {% import 'components/_macros.html.twig' as m %}
    <a href="{{ path('app_event_show', {id: p.event.id}) }}"
       class="block px-4 py-3 no-underline transition-colors"
       style="border-bottom: 1px solid var(--border-subtle)">
        <div class="flex items-center gap-3">
            <div class="w-11 h-11 rounded-lg flex-shrink-0 overflow-hidden relative" style="background: var(--bg-2)">
                <div class="w-full h-full poster-{{ p.event.type ?? 'default' }} flex items-center justify-center" style="--evt-hue: {{ event_hue(p.event) }}">
                    <span class="text-xs font-semibold text-center leading-tight" style="color: rgba(255,255,255,0.9); font-family: var(--font-mono)">
                        {{ p.event.date|date('d') }}<br><span style="font-size:9px; opacity:0.6">{{ p.event.date|date('M')|upper }}</span>
                    </span>
                </div>
            </div>
            <div class="flex-1 min-w-0">
                {% if p.event.teams %}
                <p class="font-semibold text-base truncate" style="color: var(--fg-1)">{{ p.event.teams }}</p>
                {% endif %}
                {% if p.event.tournamentName %}
                <p class="text-xs font-medium truncate mt-0.5" style="color: var(--fg-2)">{{ p.event.tournamentName }}</p>
                {% endif %}
                {% if p.event.venue %}
                <p class="text-xs mt-0.5 truncate" style="color: var(--fg-3)">{{ p.event.venue.name }}</p>
                {% endif %}
            </div>
            <div class="flex flex-col items-end gap-1 flex-shrink-0">
                {{ m.event_badge(p.event.type) }}
                {% if p.rating %}{{ m.star_rating(p.rating) }}{% endif %}
            </div>
        </div>
        {% set sl = p.event.scoreline %}
        {% if sl %}
        <p class="text-sm mt-2.5 text-center" style="color: var(--fg-2); font-family: var(--font-mono)">
            {%- if sl.winner == 1 %}🏆 {% endif %}{{ sl.team1 }} <span class="font-bold" style="color: var(--fg-1)">{{ sl.score }}</span> {{ sl.team2 }}{% if sl.winner == 2 %} 🏆{% endif -%}
        </p>
        {% elseif p.event.finalScore %}
        <p class="text-sm mt-2.5 text-center font-bold" style="color: var(--fg-1); font-family: var(--font-mono)">{{ p.event.finalScore }}</p>
        {% endif %}
    </a>
{% endmacro %}
{% endblock %}
