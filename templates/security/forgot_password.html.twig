{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié — IWasThere{% endblock %}

{% block body %}
<div class="min-h-screen flex flex-col items-center justify-center px-6 py-12">

    <div class="text-center mb-10">
        <div class="w-20 h-20 rounded-3xl flex items-center justify-center mx-auto mb-4"
             style="background: var(--positive-soft); border: 1px solid rgba(61,220,151,0.25)">
            <span class="text-3xl font-black" style="color: var(--positive)">IW</span>
        </div>
        <h1 class="text-3xl font-black" style="color: var(--fg-1)">Mot de passe oublié</h1>
        <p class="text-sm mt-1" style="color: var(--fg-3)">Saisis ton email pour recevoir un lien de réinitialisation</p>
    </div>

    <div class="w-full max-w-sm rounded-3xl p-6" style="background: var(--bg-1); border: 1px solid var(--border-subtle)">

        <form method="post" class="space-y-4">
            <div>
                <label class="block text-sm font-medium mb-1.5" style="color: var(--fg-2)">Adresse email</label>
                <input type="email" name="email" required autofocus
                       autocomplete="email"
                       class="input-field"
                       placeholder="votre@email.com">
            </div>

            <button type="submit" class="btn-primary w-full py-3 text-base">
                Envoyer le lien
            </button>
        </form>

        <p class="text-center text-sm mt-4" style="color: var(--fg-3)">
            <a href="{{ path('app_login') }}" class="font-medium" style="color: var(--positive)">← Retour à la connexion</a>
        </p>

    </div>

</div>
{% endblock %}
