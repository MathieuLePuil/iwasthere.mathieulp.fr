{% extends 'base.html.twig' %}
{% form_theme form _self %}

{% block form_errors %}
    {% if errors|length > 0 %}
        <div class="flex items-center gap-1.5 mt-1.5 text-xs font-medium rounded-lg px-3 py-2" style="background: rgba(232,155,142,0.1); border: 1px solid rgba(232,155,142,0.25); color: #E89B8E">
            <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
            <span>{% for error in errors %}{{ error.message }}{% endfor %}</span>
        </div>
    {% endif %}
{% endblock %}

{% block title %}Créer un compte — IWasThere{% endblock %}

{% block body %}
<div class="min-h-screen flex flex-col items-center justify-center px-6 py-12">

    {# Logo #}
    <div class="text-center mb-8">
        <div class="w-16 h-16 rounded-3xl flex items-center justify-center mx-auto mb-3"
             style="background: var(--positive-soft); border: 1px solid rgba(61,220,151,0.25)">
            <span class="text-2xl font-black" style="color: var(--positive)">IW</span>
        </div>
        <h1 class="text-2xl font-black" style="color: var(--fg-1)">Créer un compte</h1>
    </div>

    {# Card #}
    <div class="w-full max-w-sm rounded-3xl p-6" style="background: var(--bg-1); border: 1px solid var(--border-subtle)">

        {# Google OAuth #}
        <a href="{{ path('app_google_connect') }}"
           class="flex items-center justify-center gap-3 w-full rounded-xl py-3 mb-4 font-medium text-sm transition-colors"
           style="border: 1px solid var(--border-default); color: var(--fg-1); background: var(--bg-2)">
            <svg class="w-5 h-5" viewBox="0 0 24 24">
                <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
            </svg>
            S'inscrire avec Google
        </a>

        <div class="relative flex items-center mb-4">
            <div class="flex-1" style="border-top: 1px solid var(--border-subtle)"></div>
            <span class="px-3 text-xs" style="color: var(--fg-4)">ou</span>
            <div class="flex-1" style="border-top: 1px solid var(--border-subtle)"></div>
        </div>

        {{ form_start(form, {'attr': {'class': 'space-y-4', 'novalidate': true}}) }}

        {% for field in ['displayName', 'username', 'email'] %}
            <div{% if field == 'username' %} data-controller="username-check"{% endif %}>
                {{ form_label(form[field], null, {'label_attr': {'class': 'block text-sm font-medium mb-1.5', 'style': 'color: var(--fg-2)'}}) }}
                {% if field == 'username' %}
                    <div class="relative">
                        <span class="absolute left-4 top-1/2 -translate-y-1/2 text-sm" style="color: var(--fg-4)">@</span>
                        {{ form_widget(form[field], {'attr': {'class': 'input-field pl-7', 'data-username-check-target': 'input', 'data-action': 'input->username-check#check'}}) }}
                    </div>
                    <div data-username-check-target="feedback"></div>
                {% else %}
                    {{ form_widget(form[field]) }}
                {% endif %}
                {{ form_errors(form[field]) }}
            </div>
        {% endfor %}

        <div>
            {{ form_label(form.plainPassword.first, null, {'label_attr': {'class': 'block text-sm font-medium mb-1.5', 'style': 'color: var(--fg-2)'}}) }}
            {{ form_widget(form.plainPassword.first) }}
            {{ form_errors(form.plainPassword.first) }}
        </div>

        <div>
            {{ form_label(form.plainPassword.second, null, {'label_attr': {'class': 'block text-sm font-medium mb-1.5', 'style': 'color: var(--fg-2)'}}) }}
            {{ form_widget(form.plainPassword.second) }}
            {{ form_errors(form.plainPassword.second) }}
        </div>

        <button type="submit" class="btn-primary w-full py-3 text-base">
            Créer mon compte
        </button>

        {{ form_end(form) }}

        <p class="text-center text-sm mt-4" style="color: var(--fg-3)">
            Déjà un compte ?
            <a href="{{ path('app_login') }}" class="font-medium" style="color: var(--positive)">Se connecter</a>
        </p>

    </div>

</div>
{% endblock %}
