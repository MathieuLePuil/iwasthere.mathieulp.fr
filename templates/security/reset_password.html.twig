{% extends 'base.html.twig' %}

{% block title %}Nouveau mot de passe — IWasThere{% endblock %}

{% block body %}
<div class="min-h-screen flex flex-col items-center justify-center px-6 py-12">

    <div class="text-center mb-10">
        <img src="{{ asset('images/logo.png') }}" alt="IWasThere" class="w-20 h-20 mx-auto mb-4" style="object-fit: contain;">
        <h1 class="text-3xl font-black" style="color: var(--fg-1)">Nouveau mot de passe</h1>
        <p class="text-sm mt-1" style="color: var(--fg-3)">Choisis un nouveau mot de passe sécurisé</p>
    </div>

    <div class="w-full max-w-sm rounded-3xl p-6" style="background: var(--bg-1); border: 1px solid var(--border-subtle)">

        <form method="post" class="space-y-4" data-controller="form-loader">
            <div>
                <label class="block text-sm font-medium mb-1.5" style="color: var(--fg-2)">Nouveau mot de passe</label>
                <input type="password" name="new_password" required autofocus
                       autocomplete="new-password"
                       minlength="8"
                       class="input-field"
                       placeholder="8 caractères minimum">
            </div>

            <div>
                <label class="block text-sm font-medium mb-1.5" style="color: var(--fg-2)">Confirmer le mot de passe</label>
                <input type="password" name="confirm_password" required
                       autocomplete="new-password"
                       class="input-field"
                       placeholder="Retape ton mot de passe">
            </div>

            <button type="submit" class="btn-primary w-full py-3 text-base">
                Mettre à jour le mot de passe
            </button>
        </form>

    </div>

</div>
{% endblock %}
