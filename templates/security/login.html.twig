{% extends 'base.html.twig' %}

{% block title %}Connexion — IWasThere{% endblock %}

{% block body %}
<div class="min-h-screen flex flex-col items-center justify-center px-6 py-12">

    {# Logo #}
    <div class="text-center mb-10">
        <img src="{{ asset('images/logo.png') }}" alt="IWasThere" class="w-20 h-20 mx-auto mb-4" style="object-fit: contain;">
        <h1 class="text-3xl font-black" style="color: var(--fg-1)">IWasThere</h1>
        <p class="text-sm mt-1" style="color: var(--fg-3)">Ton journal d'expériences live</p>
    </div>

    {# Card #}
    <div class="w-full max-w-sm rounded-3xl p-6" style="background: var(--bg-1); border: 1px solid var(--border-subtle)">

        {% if error %}
            <div class="rounded-xl p-3 mb-4 text-sm" style="background: var(--negative-soft); color: var(--negative); border: 1px solid rgba(232,155,142,0.2)">
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        {# Google OAuth #}
        <a href="{{ path('app_google_connect') }}"
           class="flex items-center justify-center gap-3 w-full rounded-xl py-3 mb-4 font-medium text-sm transition-colors"
           style="border: 1px solid var(--border-default); color: var(--fg-1); background: var(--bg-2)">
            <svg class="w-5 h-5" viewBox="0 0 24 24">
                <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
            </svg>
            Continuer avec Google
        </a>

        <div class="relative flex items-center mb-4">
            <div class="flex-1" style="border-top: 1px solid var(--border-subtle)"></div>
            <span class="px-3 text-xs" style="color: var(--fg-4)">ou</span>
            <div class="flex-1" style="border-top: 1px solid var(--border-subtle)"></div>
        </div>

        {# Email/password form #}
        <form method="post" class="space-y-4">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <div>
                <label class="block text-sm font-medium mb-1.5" style="color: var(--fg-2)">Email</label>
                <input type="email" name="email" value="{{ last_username }}"
                       autocomplete="email"
                       class="input-field"
                       placeholder="votre@email.com" required>
            </div>

            <div>
                <label class="block text-sm font-medium mb-1.5" style="color: var(--fg-2)">Mot de passe</label>
                <input type="password" name="password"
                       autocomplete="current-password"
                       class="input-field"
                       placeholder="••••••••" required>
            </div>

            <div class="flex items-center justify-between">
                <label class="flex items-center gap-2 text-sm" style="color: var(--fg-3)">
                    <input type="checkbox" name="_remember_me" class="rounded">
                    Se souvenir de moi
                </label>
                <a href="{{ path('app_forgot_password') }}" class="text-sm font-medium" style="color: var(--positive)">
                    Mot de passe oublié ?
                </a>
            </div>

            <button type="submit" class="btn-primary w-full py-3 text-base">
                Connexion
            </button>
        </form>

        <p class="text-center text-sm mt-4" style="color: var(--fg-3)">
            Pas encore de compte ?
            <a href="{{ path('app_register') }}" class="font-medium" style="color: var(--positive)">S'inscrire</a>
        </p>

    </div>

</div>
{% endblock %}
