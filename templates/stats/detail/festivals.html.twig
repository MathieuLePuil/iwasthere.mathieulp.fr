{% extends 'base.html.twig' %}
{% import 'components/_macros.html.twig' as m %}

{% block title %}Mes festivals — IWasThere{% endblock %}

{% block body %}
<div class="px-4 py-5">

    <div class="flex items-center gap-3 mb-6">
        {{ m.back_button(path('app_stats')) }}
        <h1 class="text-xl font-semibold" style="color: var(--fg-1)">Mes festivals</h1>
    </div>

    {% if data.groups|length == 0 %}
        {{ m.empty_state('🎪', 'Aucun festival', 'Ajoute des concerts en festival pour voir tes stats ici', path('app_event_new'), '+ Ajouter un événement') }}
    {% else %}

    <div class="grid grid-cols-3 gap-3 mb-5">
        <div class="card text-center py-4">
            <p class="text-3xl font-black" style="color: var(--positive)">{{ data.distinct_count }}</p>
            <p class="text-xs mt-1" style="color: var(--fg-4)">Festival{{ data.distinct_count > 1 ? 's' : '' }}</p>
        </div>
        <div class="card text-center py-4">
            <p class="text-3xl font-black" style="color: var(--negative)">{{ data.editions_count }}</p>
            <p class="text-xs mt-1" style="color: var(--fg-4)">Édition{{ data.editions_count > 1 ? 's' : '' }}</p>
        </div>
        <div class="card text-center py-4">
            <p class="text-3xl font-black" style="color: #FBBF24">{{ data.total_concerts }}</p>
            <p class="text-xs mt-1" style="color: var(--fg-4)">Concert{{ data.total_concerts > 1 ? 's' : '' }}</p>
        </div>
    </div>

    <div class="space-y-3">
        {% for g in data.groups %}
        <div class="card">
            <div class="flex items-center justify-between mb-2">
                <div class="flex items-baseline gap-1.5 min-w-0">
                    <span class="font-semibold truncate" style="color: var(--fg-1)">{{ g.name }}</span>
                    <span class="text-xs flex-shrink-0" style="color: var(--fg-4)">{{ g.year }}</span>
                </div>
                <div class="flex items-center gap-2 flex-shrink-0 ml-2">
                    {% if g.avg_rating %}
                    <span class="text-xs" style="color: #FBBF24">★ {{ g.avg_rating }}</span>
                    {% endif %}
                    <span class="text-xs px-2 py-0.5 rounded-full" style="color: var(--fg-3); background: var(--bg-3)">{{ g.count }} concert{{ g.count > 1 ? 's' : '' }}</span>
                </div>
            </div>
            {% if g.artists|length > 0 %}
            <div class="flex flex-wrap gap-1.5">
                {% for artist in g.artists %}
                <span class="text-xs px-2 py-0.5 rounded-full" style="color: var(--fg-2); background: var(--bg-2); border: 1px solid var(--border-subtle)">{{ artist }}</span>
                {% endfor %}
            </div>
            {% endif %}
        </div>
        {% endfor %}
    </div>

    {% endif %}

</div>
{% endblock %}
