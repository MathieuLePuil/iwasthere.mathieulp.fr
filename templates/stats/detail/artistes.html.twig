{% extends 'base.html.twig' %}
{% import 'components/_macros.html.twig' as m %}

{% block title %}Mes artistes — IWasThere{% endblock %}

{% block body %}
<div class="px-4 py-5">

    <div class="flex items-center gap-3 mb-6">
        {{ m.back_button(path('app_stats')) }}
        <h1 class="text-xl font-semibold" style="color: var(--fg-1)">Mes artistes</h1>
    </div>

    {% if data.artists|length == 0 %}
        {{ m.empty_state('🎤', 'Aucun artiste', 'Ajoute des concerts pour voir tes artistes ici', path('app_event_new'), '+ Ajouter un événement') }}
    {% else %}

    <div class="card text-center py-5 mb-5">
        <p class="text-4xl font-black" style="color: var(--positive)">{{ data.total }}</p>
        <p class="text-xs mt-1" style="color: var(--fg-4)">Artiste{{ data.total > 1 ? 's' : '' }} différent{{ data.total > 1 ? 's' : '' }}</p>
    </div>

    <div class="card">
        <h2 class="font-medium mb-3" style="color: var(--fg-1)">Classement complet</h2>
        {% set top_count = data.artists[0].count %}
        <div class="space-y-3">
            {% set prev_count = null %}
            {% set rank = 0 %}
            {% set shown = 0 %}
            {% for a in data.artists %}
            {% if a.count != prev_count %}{% set rank = shown + 1 %}{% endif %}
            {% set shown = shown + 1 %}
            {% set prev_count = a.count %}
            <div class="flex items-start gap-3">
                <span class="text-sm font-bold w-5 pt-0.5" style="color: var(--fg-4)">{{ rank }}</span>
                {% if a.image %}
                <img src="{{ a.image }}" alt="" class="w-9 h-9 rounded-full object-cover flex-shrink-0">
                {% else %}
                <div class="w-9 h-9 rounded-full flex-shrink-0 flex items-center justify-center text-sm" style="background: var(--bg-3)">🎤</div>
                {% endif %}
                <div class="flex-1 min-w-0">
                    <div class="flex justify-between text-sm mb-1">
                        <span class="font-medium truncate" style="color: var(--fg-1)">{{ a.name }}</span>
                        <div class="flex items-center gap-2 flex-shrink-0 ml-2">
                            {% if a.avg_rating %}
                            <span class="text-xs" style="color: #FBBF24">★ {{ a.avg_rating }}</span>
                            {% endif %}
                            <span style="color: var(--fg-4)">{{ a.count }}x</span>
                        </div>
                    </div>
                    <div class="h-1.5 rounded-full overflow-hidden" style="background: var(--bg-3)">
                        <div class="h-full rounded-full" style="width: {{ (a.count / top_count * 100)|round }}%; background: var(--positive)"></div>
                    </div>
                    <p class="text-xs mt-1" style="color: var(--fg-4)">
                        {% if a.count == 1 %}
                            Vu le {{ a.last|date('d/m/Y') }}
                        {% else %}
                            Vu du {{ a.first|date('d/m/Y') }} au {{ a.last|date('d/m/Y') }}
                        {% endif %}
                    </p>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>

    {% endif %}

</div>
{% endblock %}
