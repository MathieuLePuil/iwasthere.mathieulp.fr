{% extends 'base.html.twig' %}
{% import 'components/_macros.html.twig' as m %}

{% block title %}Mes compagnons — IWasThere{% endblock %}

{% block body %}
<div class="px-4 py-5">

    <div class="flex items-center gap-3 mb-6">
        {{ m.back_button(path('app_stats')) }}
        <h1 class="text-xl font-semibold" style="color: var(--fg-1)">Mes compagnons</h1>
    </div>

    {% if data.friends|length == 0 %}
        {{ m.empty_state('👥', 'Aucun compagnon', "Ajoute des amis à tes événements pour voir avec qui tu sors le plus", path('app_event_new'), '+ Ajouter un événement') }}
    {% else %}

    <div class="card text-center py-5 mb-5">
        <p class="text-4xl font-black" style="color: var(--positive)">{{ data.total }}</p>
        <p class="text-xs mt-1" style="color: var(--fg-4)">Compagnon{{ data.total > 1 ? 's' : '' }} différent{{ data.total > 1 ? 's' : '' }}</p>
    </div>

    <div class="card">
        <h2 class="font-medium mb-3" style="color: var(--fg-1)">Classement complet</h2>
        {% set top_count = data.friends[0].count %}
        <div class="space-y-3">
            {% set prev_count = null %}
            {% set rank = 0 %}
            {% set shown = 0 %}
            {% for f in data.friends %}
            {% if f.count != prev_count %}{% set rank = shown + 1 %}{% endif %}
            {% set shown = shown + 1 %}
            {% set prev_count = f.count %}
            <div class="flex items-start gap-3">
                <span class="text-sm font-bold w-5 pt-0.5" style="color: var(--fg-4)">{{ rank }}</span>
                <div class="flex-1 min-w-0">
                    <div class="flex justify-between text-sm mb-1">
                        <span class="font-medium truncate" style="color: var(--fg-1)">{{ f.name }}</span>
                        <span class="flex-shrink-0 ml-2" style="color: var(--fg-4)">{{ f.count }} événement{{ f.count > 1 ? 's' : '' }}</span>
                    </div>
                    <div class="h-1.5 rounded-full overflow-hidden" style="background: var(--bg-3)">
                        <div class="h-full rounded-full" style="width: {{ (f.count / top_count * 100)|round }}%; background: var(--positive)"></div>
                    </div>
                    <p class="text-xs mt-1" style="color: var(--fg-4)">Dernier événement ensemble : {{ f.last|date('d/m/Y') }}</p>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>

    {% endif %}

</div>
{% endblock %}
