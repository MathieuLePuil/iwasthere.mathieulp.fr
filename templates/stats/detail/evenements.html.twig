{% extends 'base.html.twig' %}
{% import 'components/_macros.html.twig' as m %}

{% block title %}Mes événements — IWasThere{% endblock %}

{% block body %}
<div class="px-4 py-5">

    <div class="flex items-center gap-3 mb-6">
        {{ m.back_button(path('app_stats')) }}
        <h1 class="text-xl font-semibold" style="color: var(--fg-1)">Tous mes événements</h1>
    </div>

    <p class="text-sm mb-5" style="color: var(--fg-3)">{{ data.total }} événement{{ data.total > 1 ? 's' : '' }} au total</p>

    {% for year, parts in data.groups %}
    <div class="mb-5">
        <div class="flex items-center justify-between mb-2 px-1">
            <h2 class="font-semibold" style="color: var(--fg-1)">{{ year }}</h2>
            <span class="text-xs" style="color: var(--fg-4)">{{ parts|length }} événement{{ parts|length > 1 ? 's' : '' }}</span>
        </div>
        <div class="card p-0 overflow-hidden">
            {% for p in parts %}
                {{ m.event_row(p) }}
            {% endfor %}
        </div>
    </div>
    {% endfor %}

</div>
{% endblock %}
