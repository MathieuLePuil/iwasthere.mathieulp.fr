{% extends 'base.html.twig' %}

{% block title %}Mes Statistiques — IWasThere{% endblock %}

{% block body %}
<div class="px-4 py-5">

    <h1 class="text-2xl font-semibold mb-5" style="color: var(--fg-1); letter-spacing: -0.01em">Mes statistiques</h1>

    {% if not stats.has_data %}
    <div class="flex flex-col items-center justify-center py-16 text-center">
        <div class="text-6xl mb-4">📊</div>
        <h3 class="text-base font-semibold mb-2" style="color: var(--fg-1)">Pas encore de données</h3>
        <p class="text-sm mb-6" style="color: var(--fg-3)">Commence à enregistrer des événements pour voir tes statistiques</p>
        <a href="{{ path('app_event_new') }}" class="btn-primary">+ Ajouter un événement</a>
    </div>
    {% else %}

    {# Hero stats #}
    <div class="grid grid-cols-2 gap-3 mb-5">
        <div class="card text-center py-5">
            <p class="text-4xl font-black" style="color: var(--positive)">{{ stats.total }}</p>
            <p class="text-xs mt-1" style="color: var(--fg-4)">Événements</p>
        </div>
        <div class="card text-center py-5">
            <p class="text-2xl mb-1">🏟️</p>
            <p class="text-xs" style="color: var(--fg-4)">Lieu préféré</p>
            <p class="font-semibold text-sm leading-tight mt-1" style="color: var(--fg-1)">{{ stats.top_venue ?? '—' }}</p>
        </div>
        <div class="card text-center py-5">
            <p class="text-4xl font-black" style="color: #FBBF24">{{ stats.avg_rating ? stats.avg_rating ~ '/5' : '—' }}</p>
            <p class="text-xs mt-1" style="color: var(--fg-4)">Note moyenne</p>
        </div>
        <div class="card text-center py-5">
            <p class="text-4xl font-black" style="color: var(--positive)">{{ stats.venues_count }}</p>
            <p class="text-xs mt-1" style="color: var(--fg-4)">Lieux visités</p>
        </div>
    </div>

    {# Music vs Sport breakdown #}
    {% if stats.concerts > 0 or stats.festivals > 0 or stats.sports > 0 %}
    <div class="card mb-4">
        <h2 class="font-medium mb-3" style="color: var(--fg-1)">Répartition</h2>
        <div class="space-y-2">
            {% if stats.concerts > 0 %}
            <div class="flex items-center gap-3">
                <span class="text-xl">🎤</span>
                <div class="flex-1">
                    <div class="flex justify-between text-sm mb-1">
                        <span class="font-medium" style="color: var(--fg-1)">Concerts</span>
                        <span style="color: var(--fg-4)">{{ stats.concerts }}</span>
                    </div>
                    <div class="h-2 rounded-full overflow-hidden" style="background: var(--bg-3)">
                        <div class="h-full rounded-full" style="width: {{ (stats.concerts / stats.total * 100)|round }}%; background: var(--positive)"></div>
                    </div>
                </div>
            </div>
            {% endif %}
            {% if stats.festivals > 0 %}
            <div class="flex items-center gap-3">
                <span class="text-xl">🎪</span>
                <div class="flex-1">
                    <div class="flex justify-between text-sm mb-1">
                        <span class="font-medium" style="color: var(--fg-1)">Festivals</span>
                        <span style="color: var(--fg-4)">{{ stats.festivals }}</span>
                    </div>
                    <div class="h-2 rounded-full overflow-hidden" style="background: var(--bg-3)">
                        <div class="h-full rounded-full" style="width: {{ (stats.festivals / stats.total * 100)|round }}%; background: var(--negative)"></div>
                    </div>
                </div>
            </div>
            {% endif %}
            {% if stats.sports > 0 %}
            <div class="flex items-center gap-3">
                <span class="text-xl">⚽</span>
                <div class="flex-1">
                    <div class="flex justify-between text-sm mb-1">
                        <span class="font-medium" style="color: var(--fg-1)">Sport</span>
                        <span style="color: var(--fg-4)">{{ stats.sports }}</span>
                    </div>
                    <div class="h-2 rounded-full overflow-hidden" style="background: var(--bg-3)">
                        <div class="h-full rounded-full" style="width: {{ (stats.sports / stats.total * 100)|round }}%; background: #60A5FA"></div>
                    </div>
                </div>
            </div>
            {% endif %}
        </div>
    </div>
    {% endif %}

    {# Top artist #}
    {% if stats.top_artist %}
    <div class="card mb-4">
        <div class="flex items-center gap-3">
            <span class="text-4xl">🏆</span>
            <div>
                <p class="text-xs" style="color: var(--fg-4)">Artiste le plus vu</p>
                <p class="font-semibold text-lg" style="color: var(--fg-1)">{{ stats.top_artist }}</p>
                <p class="text-sm" style="color: var(--fg-3)">{{ stats.top_artist_count }} fois</p>
            </div>
        </div>
    </div>
    {% endif %}

    {# Festival stats #}
    {% if stats.top_festival %}
    <div class="card mb-4">
        <div class="flex items-center gap-2 mb-3">
            <span class="text-xl">🎪</span>
            <h2 class="font-medium" style="color: var(--fg-1)">Festivals</h2>
        </div>
        <div class="grid grid-cols-2 gap-2 mb-4">
            <div class="rounded-xl p-3 text-center" style="background: var(--bg-2)">
                <p class="text-2xl font-black" style="color: var(--positive)">{{ stats.festival_count }}</p>
                <p class="text-xs mt-0.5" style="color: var(--fg-4)">Festival{{ stats.festival_count > 1 ? 's' : '' }} différent{{ stats.festival_count > 1 ? 's' : '' }}</p>
            </div>
            <div class="rounded-xl p-3 text-center" style="background: var(--bg-2)">
                <p class="text-2xl font-black" style="color: var(--negative)">{{ stats.top_festival.count }}</p>
                <p class="text-xs mt-0.5" style="color: var(--fg-4)">Record de concerts</p>
            </div>
        </div>
        {% if stats.festival_groups|length > 0 %}
        <div class="space-y-3">
            {% set top_count = stats.festival_groups[0].count %}
            {% for fest in stats.festival_groups %}
            <div>
                <div class="flex justify-between text-sm mb-1">
                    <div class="flex items-baseline gap-1.5 min-w-0">
                        <span class="font-medium truncate" style="color: var(--fg-1)">{{ fest.name }}</span>
                        <span class="text-xs flex-shrink-0" style="color: var(--fg-4)">{{ fest.year }}</span>
                    </div>
                    <div class="flex items-center gap-2 flex-shrink-0 ml-2">
                        {% if fest.avg_rating %}
                        <span class="text-xs" style="color: #FBBF24">★ {{ fest.avg_rating }}</span>
                        {% endif %}
                        <span style="color: var(--fg-4)">{{ fest.count }} concert{{ fest.count > 1 ? 's' : '' }}</span>
                    </div>
                </div>
                <div class="h-1.5 rounded-full overflow-hidden" style="background: var(--bg-3)">
                    <div class="h-full rounded-full" style="width: {{ (fest.count / top_count * 100)|round }}%; background: var(--negative)"></div>
                </div>
            </div>
            {% endfor %}
        </div>
        {% endif %}
    </div>
    {% endif %}

    {# Top artists list #}
    {% if stats.artists|length > 1 %}
    <div class="card mb-4">
        <h2 class="font-medium mb-3" style="color: var(--fg-1)">Top Artistes</h2>
        <div class="space-y-2">
            {% set prev_count = null %}
            {% set rank = 0 %}
            {% set shown = 0 %}
            {% for artist, count in stats.artists %}
            {% if count != prev_count %}{% set rank = shown + 1 %}{% endif %}
            {% set shown = shown + 1 %}
            {% set prev_count = count %}
            <div class="flex items-center gap-3">
                <span class="text-sm font-bold w-5" style="color: var(--fg-4)">{{ rank }}</span>
                <div class="flex-1">
                    <div class="flex justify-between text-sm">
                        <span class="font-medium" style="color: var(--fg-1)">{{ artist }}</span>
                        <span style="color: var(--fg-4)">{{ count }}x</span>
                    </div>
                    <div class="h-1.5 rounded-full mt-1 overflow-hidden" style="background: var(--bg-3)">
                        <div class="h-full rounded-full" style="width: {{ (count / stats.top_artist_count * 100)|round }}%; background: var(--positive)"></div>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
    {% endif %}

    {# Events per year #}
    {% if stats.by_year|length > 1 %}
    <div class="card mb-4">
        <h2 class="font-medium mb-3" style="color: var(--fg-1)">Par année</h2>
        {% set max_year = max(stats.by_year) %}
        <div class="space-y-2">
            {% for year in stats.by_year|keys|sort|reverse %}
            {% set count = stats.by_year[year] %}
            <div class="flex items-center gap-3">
                <span class="text-sm font-medium w-12" style="color: var(--fg-3)">{{ year }}</span>
                <div class="flex-1 h-6 rounded-lg overflow-hidden" style="background: var(--bg-3)">
                    <div class="h-full rounded-lg flex items-center px-2"
                         style="width: max({{ (count / max_year * 100)|round }}%, 30px); background: var(--positive)">
                        <span class="text-xs font-bold" style="color: #0B0D10">{{ count }}</span>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
    {% endif %}

    {# By month #}
    {% if stats.by_month|length > 0 %}
    <div class="card mb-4">
        <h2 class="font-medium mb-3" style="color: var(--fg-1)">Par mois</h2>
        {% set month_names = {1: 'Jan', 2: 'Fév', 3: 'Mar', 4: 'Avr', 5: 'Mai', 6: 'Jun', 7: 'Jul', 8: 'Aoû', 9: 'Sep', 10: 'Oct', 11: 'Nov', 12: 'Déc'} %}
        {% set max_month = max(stats.by_month) %}
        <div class="flex items-end gap-1 h-20">
            {% for mo in 1..12 %}
            {% set count = stats.by_month[mo] ?? 0 %}
            <div class="flex-1 flex flex-col items-center gap-1">
                <div class="w-full rounded-t-sm transition-all"
                     style="height: {{ max_month > 0 ? (count / max_month * 56)|round : 0 }}px; min-height: {{ count > 0 ? 4 : 0 }}px; background: var(--positive)">
                </div>
                <span class="text-[8px]" style="color: var(--fg-4)">{{ month_names[mo] }}</span>
            </div>
            {% endfor %}
        </div>
    </div>
    {% endif %}

    {# Streak #}
    {% if stats.max_streak > 1 %}
    <div class="card mb-4">
        <div class="flex items-center justify-between">
            <div>
                <p class="text-xs" style="color: var(--fg-4)">Meilleure série</p>
                <p class="text-2xl font-black" style="color: var(--positive)">{{ stats.max_streak }} jours consécutifs</p>
            </div>
            <span class="text-4xl">🔥</span>
        </div>
        {% if stats.streak > 0 %}
        <p class="text-sm mt-1" style="color: var(--fg-3)">Série actuelle : <span class="font-bold" style="color: var(--positive)">{{ stats.streak }} jour{{ stats.streak > 1 ? 's' : '' }}</span></p>
        {% endif %}
    </div>
    {% endif %}

    {# First & last event #}
    {% if stats.first_date %}
    <div class="card mb-4">
        <h2 class="font-medium mb-3" style="color: var(--fg-1)">Période</h2>
        <div class="flex justify-between">
            <div>
                <p class="text-xs" style="color: var(--fg-4)">Premier événement</p>
                <p class="font-semibold" style="color: var(--fg-1)">{{ stats.first_date|date('d/m/Y') }}</p>
            </div>
            <div class="text-right">
                <p class="text-xs" style="color: var(--fg-4)">Dernier événement</p>
                <p class="font-semibold" style="color: var(--fg-1)">{{ stats.last_date|date('d/m/Y') }}</p>
            </div>
        </div>
    </div>
    {% endif %}

    {# Friends at events #}
    {% if stats.friends_stats|length > 0 %}
    <div class="card mb-4">
        <h2 class="font-medium mb-3" style="color: var(--fg-1)">Meilleurs compagnons</h2>
        <div class="space-y-2">
            {% for name, count in stats.friends_stats %}
            <div class="flex items-center justify-between">
                <span class="font-medium text-sm" style="color: var(--fg-1)">{{ name }}</span>
                <span class="text-xs px-2 py-0.5 rounded-full" style="color: var(--fg-3); background: var(--bg-3)">{{ count }} événement{{ count > 1 ? 's' : '' }}</span>
            </div>
            {% endfor %}
        </div>
    </div>
    {% endif %}

    {% endif %} {# end has_data #}

</div>
{% endblock %}
