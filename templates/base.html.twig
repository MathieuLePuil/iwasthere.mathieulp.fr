<!DOCTYPE html>
{# data-theme-pref porte le choix de l'utilisateur ('dark'/'light'/'auto'), data-theme le thème
   effectivement appliqué — seul ce dernier est lu par le CSS. Le rendu serveur pose déjà la valeur
   finale sauf en 'auto', que seul le client sait résoudre (voir le script plus bas). #}
{% set theme_pref = app.user ? app.user.theme : 'dark' %}
<html lang="fr" data-theme-pref="{{ theme_pref }}" data-theme="{{ theme_pref == 'light' ? 'light' : 'dark' }}">
    <head>
        <meta charset="UTF-8">
        {# Comme myrenault : PAS de metas legacy apple-mobile-web-app-* — avec elles, iOS 26
           lance la PWA dans l'ancien mode "web clip" à la géométrie cassée (bande réservée en
           bas, env() faux). Le manifest display:standalone suffit pour le mode plein écran.
           maximum-scale coupe le tap-zoom iOS (effet zoom au changement de page) sans interdire
           le zoom manuel, contrairement à user-scalable=no. #}
        <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, viewport-fit=cover">
        {# Rendu serveur dès que le thème est connu : iOS lit theme-color très tôt, le corriger
           en JS laisserait la barre d'état clignoter. Seul 'auto' est laissé au client. #}
        <meta name="theme-color" content="{{ theme_pref == 'light' ? '#EFEFEA' : '#0B0D10' }}">
        {# Avant tout rendu, sinon 'auto' sur un téléphone en clair afficherait un flash sombre.
           Les couleurs sont celles de --bg-0 : theme-color est lu par iOS avant le CSS, on ne peut
           pas le déduire des tokens.
           data-cfasync="false" : sans lui, le Rocket Loader de Cloudflare réécrit le type du script
           et le rejoue après le premier rendu — ce qui rendrait ce bloc inutile (flash garanti). #}
        <script data-cfasync="false">
        (function () {
            var root = document.documentElement;
            var mq = window.matchMedia('(prefers-color-scheme: light)');
            window.iwtApplyTheme = function () {
                var pref = root.dataset.themePref || 'dark';
                var theme = pref === 'auto' ? (mq.matches ? 'light' : 'dark') : pref;
                root.dataset.theme = theme;
                var meta = document.querySelector('meta[name="theme-color"]');
                if (meta) meta.setAttribute('content', theme === 'light' ? '#EFEFEA' : '#0B0D10');
            };
            mq.addEventListener('change', window.iwtApplyTheme);
            window.iwtApplyTheme();
        })();
        </script>
        <link rel="manifest" href="/manifest.json">
        <link rel="icon" type="image/png" sizes="32x32" href="{{ asset('images/icons/icon-32.png') }}">
        <link rel="icon" type="image/png" sizes="16x16" href="{{ asset('images/icons/icon-16.png') }}">
        <link rel="apple-touch-icon" sizes="180x180" href="{{ asset('images/icons/apple-touch-icon.png') }}">
        <link rel="apple-touch-icon" href="{{ asset('images/icons/apple-touch-icon.png') }}">
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&family=Geist+Mono:wght@400;500;600&display=swap">
        <title>{% block title %}IWasThere{% endblock %}</title>
        {% block stylesheets %}{% endblock %}
        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body class="antialiased">

        {% if app.user %}
        {# ── Fixed top header ── #}
        <header id="app-header" class="fixed top-0 inset-x-0 z-30 h-14 app-header flex items-center px-4 gap-3" data-turbo-permanent
                style="padding-top: env(safe-area-inset-top, 0px); height: calc(3.5rem + env(safe-area-inset-top, 0px))">
            <a href="{{ path('app_home') }}">
                <img src="{{ asset('images/logo.png') }}" alt="IWasThere" style="height: 48px; width: auto; display: block;">
            </a>
            <div class="flex-1"></div>
            {%- set _unread = unread_notifications_count() -%}
            <a href="{{ path('app_notifications') }}" class="iwt-icon-btn"
               data-controller="notification-badge"
               data-notification-badge-count-value="{{ _unread }}">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9M10 21a2 2 0 0 0 4 0"/>
                </svg>
                <span data-notification-badge-target="badge"
                      class="absolute top-0.5 right-0.5 min-w-[16px] h-4 text-[9px] font-bold rounded-full flex items-center justify-center px-0.5"
                      style="background: var(--positive); color: #0B0D10; {% if _unread == 0 %}display:none{% endif %}">
                    {{ _unread > 9 ? '9+' : _unread }}
                </span>
            </a>
            <a href="{{ path('app_settings') }}" class="iwt-icon-btn">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6z"/>
                    <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 1 1-4 0v-.09a1.65 1.65 0 0 0-1-1.51 1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 1 1 0-4h.09A1.65 1.65 0 0 0 4.6 9 1.65 1.65 0 0 0 4.27 7.18l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 1 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 1 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
                </svg>
            </a>
        </header>
        {% endif %}

        {# ── Main content ── #}
        {# Flux normal, le document scrolle nativement (architecture myrenault) #}
        <main style="min-height: 100vh; {% if app.user %}padding-top: calc(3.5rem + env(safe-area-inset-top, 0px)); padding-bottom: 6rem;{% endif %}">
            {# Flash messages — l'habillage vit dans .iwt-flash (app.css), pour que le thème
               clair puisse réécrire les couleurs ; un style inline ne se surcharge pas. #}
            {% for type, messages in app.flashes %}
                {% for message in messages %}
                {# Un type hors catalogue (addFlash libre) retombe sur 'info' plutôt que de
                   sortir sans couleurs. #}
                {% set variant = type in ['success', 'error', 'warning'] ? type : 'info' %}
                <div data-controller="flash-message" class="iwt-flash iwt-flash--{{ variant }}">
                    {% if variant == 'success' %}
                    <svg class="iwt-flash-icon" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg>
                    {% elseif variant == 'error' %}
                    <svg class="iwt-flash-icon" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12"/></svg>
                    {% elseif variant == 'warning' %}
                    <svg class="iwt-flash-icon" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M12 9v4M12 17h.01M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/></svg>
                    {% else %}
                    <svg class="iwt-flash-icon" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
                    {% endif %}
                    <span class="iwt-flash-text">{{ message }}</span>
                </div>
                {% endfor %}
            {% endfor %}

            {% block body %}{% endblock %}
        </main>

        {% if app.user %}
        {# ── Bottom nav — flex child of <body>, glued to the physical screen bottom (see .app-nav in app.css) ── #}
        {% set current_route = app.request.attributes.get('_route') %}
        <nav id="app-nav" class="app-nav">
            <div class="app-nav-inner">

                {# Accueil #}
                <a href="{{ path('app_home') }}" class="app-nav-link{{ current_route == 'app_home' ? ' is-active' }}">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2h-4v-7H10v7H6a2 2 0 0 1-2-2z" fill="{{ current_route == 'app_home' ? 'currentColor' : 'none' }}"/>
                    </svg>
                    Accueil
                </a>

                {# Musique #}
                <a href="{{ path('app_music') }}" class="app-nav-link{{ current_route starts with 'app_music' ? ' is-active' }}">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M9 18V5l12-2v13"/>
                        <circle cx="6" cy="18" r="3"/>
                        <circle cx="18" cy="16" r="3"/>
                    </svg>
                    Musique
                </a>

                {# Sport #}
                <a href="{{ path('app_sport') }}" class="app-nav-link{{ current_route starts with 'app_sport' ? ' is-active' }}">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/>
                        <path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/>
                        <path d="M4 22h16"/>
                        <path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/>
                        <path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/>
                        <path d="M18 2H6v7a6 6 0 0 0 12 0V2z"/>
                    </svg>
                    Sport
                </a>

                {# Stats #}
                <a href="{{ path('app_stats') }}" class="app-nav-link{{ current_route == 'app_stats' ? ' is-active' }}">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 3v18h18M19 9l-5 5-4-4-3 3"/>
                    </svg>
                    Stats
                </a>

                {# Profil #}
                <a href="{{ path('app_profile') }}" class="app-nav-link{{ current_route starts with 'app_profile' ? ' is-active' }}">
                    {% if app.user.avatarUrl %}
                        <img src="{{ app.user.avatarUrl }}" class="w-6 h-6 rounded-full object-cover" alt=""
                             style="{{ current_route starts with 'app_profile' ? 'box-shadow: 0 0 0 2px var(--positive)' : '' }}"
                             onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
                        <div class="w-6 h-6 rounded-full items-center justify-center text-[10px] font-bold" style="display:none;background: var(--positive-soft); color: var(--positive)">{{ app.user.displayName|first|upper }}</div>
                    {% else %}
                        <div class="w-6 h-6 rounded-full flex items-center justify-center text-[10px] font-bold"
                             style="background: var(--positive-soft); color: var(--positive)">
                            {{ app.user.displayName|first|upper }}
                        </div>
                    {% endif %}
                    Profil
                </a>

            </div>
        </nav>
        {% endif %}

    <script>
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('/sw.js').catch(() => {});
        }
    </script>
    {% if app.user and vapid_public_key is defined and vapid_public_key %}
    <script data-turbo-eval="false">
    (function() {
        if (!('serviceWorker' in navigator) || Notification.permission !== 'granted') return;
        navigator.serviceWorker.ready.then(function(reg) {
            return reg.pushManager.getSubscription();
        }).then(function(sub) {
            if (!sub) return;
            fetch('{{ path('app_subscribe') }}', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(sub),
            }).catch(() => {});
        }).catch(() => {});
    })();
    </script>
    {% endif %}
    </body>
</html>
