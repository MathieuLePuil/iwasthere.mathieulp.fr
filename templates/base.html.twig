<!DOCTYPE html>
<html lang="fr" data-theme="dark">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
        <meta name="theme-color" content="#B060FF">
        <meta name="apple-mobile-web-app-capable" content="yes">
        <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
        <meta name="apple-mobile-web-app-title" content="IWasThere">
        <link rel="manifest" href="/manifest.json">
        <link rel="icon" type="image/png" sizes="32x32" href="{{ asset('images/icons/icon-32.png') }}">
        <link rel="icon" type="image/png" sizes="16x16" href="{{ asset('images/icons/icon-16.png') }}">
        <link rel="apple-touch-icon" sizes="180x180" href="{{ asset('images/icons/apple-touch-icon.png') }}">
        <link rel="apple-touch-icon" href="{{ asset('images/icons/apple-touch-icon.png') }}">
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&family=Geist+Mono:wght@400;500;600&display=swap">
        <title>{% block title %}IWasThere{% endblock %}</title>
        {% block stylesheets %}{% endblock %}
        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body class="antialiased">

        {% if app.user %}
        {# ── Fixed top header ── #}
        <header id="app-header" class="fixed top-0 inset-x-0 z-30 h-14 app-header flex items-center px-4 gap-3"
                style="padding-top: env(safe-area-inset-top, 0px); height: calc(3.5rem + env(safe-area-inset-top, 0px))">
            <a href="{{ path('app_home') }}">
                <img src="{{ asset('images/logo.png') }}" alt="IWasThere" style="height: 48px; width: auto; display: block;">
            </a>
            <div class="flex-1"></div>
            {%- set _unread = unread_notifications_count() -%}
            <a href="{{ path('app_notifications') }}" class="iwt-icon-btn"
               data-controller="notification-badge"
               data-notification-badge-count-value="{{ _unread }}">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9M10 21a2 2 0 0 0 4 0"/>
                </svg>
                <span data-notification-badge-target="badge"
                      class="absolute top-0.5 right-0.5 min-w-[16px] h-4 text-[9px] font-bold rounded-full flex items-center justify-center px-0.5"
                      style="background: var(--positive); color: #0B0D10; {% if _unread == 0 %}display:none{% endif %}">
                    {{ _unread > 9 ? '9+' : _unread }}
                </span>
            </a>
            <a href="{{ path('app_settings') }}" class="iwt-icon-btn">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6z"/>
                    <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 1 1-4 0v-.09a1.65 1.65 0 0 0-1-1.51 1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 1 1 0-4h.09A1.65 1.65 0 0 0 4.6 9 1.65 1.65 0 0 0 4.27 7.18l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 1 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 1 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
                </svg>
            </a>
        </header>
        {% endif %}

        {# ── Main content ── #}
        <main class="overscroll-none"
              style="height: 100%; overflow-y: scroll; -webkit-overflow-scrolling: touch; {% if app.user %}padding-top: calc(3.5rem + env(safe-area-inset-top, 0px)); padding-bottom: calc(4rem + env(safe-area-inset-bottom, 0px));{% endif %}">
            {# Flash messages #}
            {% for type, messages in app.flashes %}
                {% for message in messages %}
                <div data-controller="flash-message"
                     class="fixed inset-x-4 z-40 flex items-center gap-3 rounded-xl px-4 py-3.5 shadow-2xl"
                     style="top: calc(4rem + env(safe-area-inset-top, 0px)); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
                        {% if type == 'success' %}
                            background: color-mix(in srgb, #0d1f12 90%, transparent);
                            border: 1px solid rgba(74, 222, 128, 0.35);
                            box-shadow: 0 8px 32px rgba(0,0,0,0.5), 0 0 0 1px rgba(74,222,128,0.1);
                        {% elseif type == 'error' %}
                            background: color-mix(in srgb, #1f0d0d 90%, transparent);
                            border: 1px solid rgba(232, 155, 142, 0.35);
                            box-shadow: 0 8px 32px rgba(0,0,0,0.5), 0 0 0 1px rgba(232,155,142,0.1);
                        {% elseif type == 'warning' %}
                            background: color-mix(in srgb, #1c1600 90%, transparent);
                            border: 1px solid rgba(251, 191, 36, 0.35);
                            box-shadow: 0 8px 32px rgba(0,0,0,0.5);
                        {% else %}
                            background: color-mix(in srgb, #0d1220 90%, transparent);
                            border: 1px solid rgba(96, 165, 250, 0.35);
                            box-shadow: 0 8px 32px rgba(0,0,0,0.5);
                        {% endif %}
                     ">
                    {# Icon #}
                    {% if type == 'success' %}
                    <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="#4ade80" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg>
                    {% elseif type == 'error' %}
                    <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="#E89B8E" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12"/></svg>
                    {% elseif type == 'warning' %}
                    <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="#FBBF24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M12 9v4M12 17h.01M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/></svg>
                    {% else %}
                    <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="#60A5FA" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
                    {% endif %}
                    <span class="text-sm font-medium" style="color: var(--fg-1)">{{ message }}</span>
                </div>
                {% endfor %}
            {% endfor %}

            {% block body %}{% endblock %}
        </main>

        {% if app.user %}
        {# ── Fixed bottom nav ── #}
        {% set current_route = app.request.attributes.get('_route') %}
        <nav id="app-nav" class="fixed bottom-0 inset-x-0 z-30 app-nav" style="padding-bottom: env(safe-area-inset-bottom)">
            <div class="flex items-center h-16 max-w-lg mx-auto px-2">

                {# Accueil #}
                <a href="{{ path('app_home') }}" data-nav-path="/"
                   class="flex-1 flex flex-col items-center gap-0.5 py-2 transition-colors text-[11px] font-medium nav-link"
                   style="color: {{ current_route == 'app_home' ? 'var(--positive)' : 'var(--fg-4)' }}">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2h-4v-7H10v7H6a2 2 0 0 1-2-2z" fill="{{ current_route == 'app_home' ? 'currentColor' : 'none' }}" data-nav-fill/>
                    </svg>
                    Accueil
                </a>

                {# Musique #}
                <a href="{{ path('app_music') }}" data-nav-path="/music"                   class="flex-1 flex flex-col items-center gap-0.5 py-2 transition-colors text-[11px] font-medium nav-link"
                   style="color: {{ current_route starts with 'app_music' ? 'var(--positive)' : 'var(--fg-4)' }}">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M9 18V5l12-2v13"/>
                        <circle cx="6" cy="18" r="3"/>
                        <circle cx="18" cy="16" r="3"/>
                    </svg>
                    Musique
                </a>

                {# Sport #}
                <a href="{{ path('app_sport') }}" data-nav-path="/sport"                   class="flex-1 flex flex-col items-center gap-0.5 py-2 transition-colors text-[11px] font-medium nav-link"
                   style="color: {{ current_route starts with 'app_sport' ? 'var(--positive)' : 'var(--fg-4)' }}">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/>
                        <path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/>
                        <path d="M4 22h16"/>
                        <path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/>
                        <path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/>
                        <path d="M18 2H6v7a6 6 0 0 0 12 0V2z"/>
                    </svg>
                    Sport
                </a>

                {# Stats #}
                <a href="{{ path('app_stats') }}" data-nav-path="/stats"                   class="flex-1 flex flex-col items-center gap-0.5 py-2 transition-colors text-[11px] font-medium nav-link"
                   style="color: {{ current_route == 'app_stats' ? 'var(--positive)' : 'var(--fg-4)' }}">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 3v18h18M19 9l-5 5-4-4-3 3"/>
                    </svg>
                    Stats
                </a>

                {# Profil #}
                <a href="{{ path('app_profile') }}" data-nav-path="/profile"
                   class="flex-1 flex flex-col items-center gap-0.5 py-2 transition-colors text-[11px] font-medium nav-link"
                   style="color: {{ current_route starts with 'app_profile' ? 'var(--positive)' : 'var(--fg-4)' }}">
                    {% if app.user.avatarUrl %}
                        <img src="{{ app.user.avatarUrl }}" class="w-6 h-6 rounded-full object-cover" alt=""
                             style="{{ current_route starts with 'app_profile' ? 'box-shadow: 0 0 0 2px var(--positive)' : '' }}"
                             onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
                        <div class="w-6 h-6 rounded-full items-center justify-center text-[10px] font-bold" style="display:none;background: var(--positive-soft); color: var(--positive)">{{ app.user.displayName|first|upper }}</div>
                    {% else %}
                        <div class="w-6 h-6 rounded-full flex items-center justify-center text-[10px] font-bold"
                             style="background: var(--positive-soft); color: var(--positive)">
                            {{ app.user.displayName|first|upper }}
                        </div>
                    {% endif %}
                    Profil
                </a>

            </div>
        </nav>
        {% endif %}

    <script>
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('/sw.js').catch(() => {});
        }
    </script>
    {% if app.user and vapid_public_key is defined and vapid_public_key %}
    <script data-turbo-eval="false">
    (function() {
        if (!('serviceWorker' in navigator) || Notification.permission !== 'granted') return;
        navigator.serviceWorker.ready.then(function(reg) {
            return reg.pushManager.getSubscription();
        }).then(function(sub) {
            if (!sub) return;
            fetch('{{ path('app_subscribe') }}', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(sub),
            }).catch(() => {});
        }).catch(() => {});
    })();
    </script>
    {% endif %}
    </body>
</html>
