{% extends 'base.html.twig' %}
{% import 'components/_macros.html.twig' as m %}

{% block title %}Accueil — IWasThere{% endblock %}

{% block body %}
<div class="px-4 py-5 space-y-5">

    {# Greeting #}
    <div class="flex items-center justify-between">
        <div>
            <p class="section-title">Bonsoir</p>
            <h1 class="text-2xl font-semibold tracking-tight" style="color: var(--fg-1); letter-spacing: -0.01em">{{ app.user.displayName }}</h1>
        </div>
        {% if app.user.avatarUrl %}
            <img src="{{ app.user.avatarUrl }}" class="w-11 h-11 rounded-2xl object-cover" alt=""
                 onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
            <div class="w-11 h-11 rounded-2xl items-center justify-center font-bold text-lg" style="display:none;background: var(--positive-soft); color: var(--positive)">
                {{ app.user.displayName|first|upper }}
            </div>
        {% else %}
            <div class="w-11 h-11 rounded-2xl flex items-center justify-center font-bold text-lg"
                 style="background: var(--positive-soft); color: var(--positive)">
                {{ app.user.displayName|first|upper }}
            </div>
        {% endif %}
    </div>

    {# Pending reminders #}
    {% if pending_reminders|length > 0 %}
    <div>
        <p class="section-title mb-2">À compléter</p>
        <div class="iwt-reminder">
            <div class="iwt-reminder-icon">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 3l1.7 4.6 4.6 1.7-4.6 1.7L12 15.6 10.3 11l-4.6-1.7L10.3 7.6z"/>
                </svg>
            </div>
            <div class="iwt-reminder-body">
                <span class="iwt-reminder-title">{{ pending_reminders|length }} fiche{{ pending_reminders|length > 1 ? 's' : '' }} à compléter</span>
                <span class="iwt-reminder-sub">
                    {% for p in pending_reminders|slice(0, 1) %}{{ p.event.artistName ?? p.event.tournamentName ?? 'Événement' }}{% endfor %}{% if pending_reminders|length > 1 %} +{{ pending_reminders|length - 1 }} autre{{ pending_reminders|length > 2 ? 's' : '' }}{% endif %}
                </span>
            </div>
            <a href="{{ path('app_event_show', {id: pending_reminders[0].event.id}) }}" class="iwt-reminder-cta">
                Compléter
            </a>
        </div>
    </div>
    {% endif %}

    {# Next event countdown #}
    <div>
        <div class="flex items-center justify-between mb-2">
            <p class="section-title">Prochain événement</p>
        </div>
        {% if next_event %}
        {% set type_emoji = {'concert': '🎤', 'festival': '🎪', 'football': '⚽', 'rugby': '🏉', 'tennis': '🎾'} %}
        <div class="iwt-hero">
            <div class="iwt-hero-poster{% if not next_event.event.artistImageUrl %} poster-{{ next_event.event.type ?? 'default' }}{% endif %}"
                 {% if next_event.event.artistImageUrl %}style="background: linear-gradient(180deg, rgba(11,13,16,0.2) 0%, rgba(11,13,16,0.75) 100%), url('{{ next_event.event.artistImageUrl }}') center 25%/cover"{% endif %}>
                <span class="iwt-hero-art-tag iwt-hero-art-tag--{{ next_event.event.type ?? 'default' }}">{{ type_emoji[next_event.event.type] ?? '🎫' }} {{ next_event.event.type ? next_event.event.type|capitalize : 'Événement' }}</span>
                <div class="poster-title">
                    <span class="name">{{ next_event.event.artistName ?? next_event.event.tournamentName ?? 'Événement' }}</span>
                    {% if next_event.event.venue %}
                    <span class="when">{{ next_event.event.date|date('d/m/Y') }} · {{ next_event.event.venue.name }}</span>
                    {% else %}
                    <span class="when">{{ next_event.event.date|date('d/m/Y') }}</span>
                    {% endif %}
                </div>
            </div>
            <div class="iwt-hero-body">
                <div class="iwt-countdown" data-controller="countdown" data-countdown-date-value="{{ next_event.event.startDateTime|date('Y-m-d\\TH:i:s') }}">
                    <div class="iwt-countdown-cell"><span class="iwt-countdown-num" data-countdown-target="days">--</span><span class="iwt-countdown-lbl">jours</span></div>
                    <div class="iwt-countdown-cell"><span class="iwt-countdown-num" data-countdown-target="hours">--</span><span class="iwt-countdown-lbl">h</span></div>
                    <div class="iwt-countdown-cell"><span class="iwt-countdown-num" data-countdown-target="minutes">--</span><span class="iwt-countdown-lbl">min</span></div>
                    <div class="iwt-countdown-cell"><span class="iwt-countdown-num" data-countdown-target="seconds">--</span><span class="iwt-countdown-lbl">sec</span></div>
                </div>
                <a href="{{ path('app_event_show', {id: next_event.event.id}) }}"
                   class="text-sm font-medium text-right block" style="color: var(--positive)">
                    Voir la fiche →
                </a>
            </div>
        </div>
        {% else %}
        <div class="iwt-hero">
            <div class="iwt-hero-body" style="align-items: center; text-align: center; padding: 2rem 1rem">
                <p class="section-title">Aucun événement à venir</p>
                <a href="{{ path('app_event_new') }}" class="btn-primary mt-2">+ Ajouter un événement</a>
            </div>
        </div>
        {% endif %}
    </div>

    {# Friends activity (preview of /feed) #}
    <div>
        <div class="flex items-center justify-between mb-2">
            <p class="section-title">Activité des amis</p>
            <a href="{{ path('app_feed') }}" class="text-xs font-medium" style="color: var(--fg-2)">Tout voir →</a>
        </div>
        {% if feed_preview|length > 0 %}
        <div class="card" style="padding: 0; overflow: hidden">
            {% for g in feed_preview %}
            {% set n = g.participations|length %}
            {% set firstUser = (g.participations|first).user %}
            <a href="{{ path('app_event_show', {id: g.event.id}) }}"
               class="flex items-center gap-3 px-4 py-3 no-underline transition-colors"
               style="border-bottom: {% if not loop.last %}1px solid var(--border-subtle){% else %}none{% endif %}">
                <div class="flex -space-x-2 flex-shrink-0">
                    {% for p in g.participations|slice(0, 2) %}
                        <span class="inline-flex rounded-full" style="box-shadow: 0 0 0 2px var(--bg-1)">{{ m.avatar(p.user, 'sm') }}</span>
                    {% endfor %}
                </div>
                <div class="flex-1 min-w-0">
                    <p class="text-sm leading-snug truncate" style="color: var(--fg-2)">
                        <span class="font-semibold" style="color: var(--fg-1)">{{ firstUser.displayName }}</span>
                        {%- if n > 1 %} et {{ n - 1 }} autre{{ n > 2 ? 's' }}{% endif %}
                        {{ n > 1 ? 'étaient à' : 'était à' }}
                    </p>
                    <p class="text-xs mt-0.5 truncate" style="color: var(--fg-3)">
                        {{ g.event.artistName ?? g.event.tournamentName ?? g.event.teams ?? 'Événement' }}
                    </p>
                </div>
                <span class="text-[11px] flex-shrink-0" style="color: var(--fg-4)">{{ g.date_label }}</span>
            </a>
            {% endfor %}
        </div>
        {% elseif feed_friend_count == 0 %}
        <a href="{{ path('app_profile_search') }}" class="card flex items-center gap-3 no-underline">
            <div class="w-9 h-9 rounded-xl flex items-center justify-center flex-shrink-0 text-lg" style="background: var(--positive-soft)">👋</div>
            <div class="flex-1 min-w-0">
                <p class="text-sm font-medium" style="color: var(--fg-1)">Ajoute des amis</p>
                <p class="text-xs" style="color: var(--fg-3)">Retrouve leurs concerts et matchs ici</p>
            </div>
            <span class="text-xs font-medium flex-shrink-0" style="color: var(--positive)">Chercher →</span>
        </a>
        {% else %}
        <a href="{{ path('app_feed') }}" class="card block no-underline text-center py-5">
            <p class="text-sm" style="color: var(--fg-3)">Aucune activité récente de tes amis</p>
        </a>
        {% endif %}
    </div>

    {# Recent events #}
    {% if recent_past|length > 0 %}
    <div>
        <div class="flex items-center justify-between mb-2">
            <p class="section-title">Derniers souvenirs</p>
            <a href="{{ path('app_music') }}" class="text-xs font-medium" style="color: var(--fg-2)">Tout voir →</a>
        </div>
        <div class="card" style="padding: 0; overflow: hidden">
            {% for p in recent_past %}
            <a href="{{ path('app_event_show', {id: p.event.id}) }}"
               class="flex items-center gap-3 px-4 py-3 no-underline transition-colors"
               style="border-bottom: {% if not loop.last %}1px solid var(--border-subtle){% else %}none{% endif %}"
>
                {{ m.event_thumb(p.event) }}
                <div class="flex-1 min-w-0">
                    <p class="font-medium text-sm truncate" style="color: var(--fg-1)">{{ p.event.artistName ?? p.event.tournamentName ?? 'Événement' }}</p>
                    <p class="text-xs mt-0.5" style="color: var(--fg-3)">
                        {% if p.event.venue %}{{ p.event.venue.name }}{% endif %}
                    </p>
                </div>
                <div class="flex flex-col items-end gap-1">
                    {% if p.rating %}
                        {{ m.star_rating(p.rating) }}
                    {% else %}
                        {{ m.event_badge(p.event.type) }}
                    {% endif %}
                </div>
            </a>
            {% endfor %}
        </div>
    </div>
    {% else %}
    <div class="card text-center py-10">
        <p class="text-4xl mb-3">🎤</p>
        <p class="font-semibold text-sm" style="color: var(--fg-1)">Ton journal est vide</p>
        <p class="text-xs mt-1 mb-4" style="color: var(--fg-3)">Commence par ajouter ton premier événement</p>
        <a href="{{ path('app_event_new') }}" class="btn-primary">+ Ajouter un événement</a>
    </div>
    {% endif %}

</div>
{% endblock %}
