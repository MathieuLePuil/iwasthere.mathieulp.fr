{% extends 'base.html.twig' %}
{% import 'components/_macros.html.twig' as m %}

{% block title %}Paramètres — IWasThere{% endblock %}

{% block body %}
<div class="px-4 py-5 space-y-5">

    <h1 class="text-2xl font-semibold" style="color: var(--fg-1); letter-spacing: -0.01em">Paramètres</h1>

    {# ── Profile section ── #}
    <div class="card">
        <h2 class="font-medium mb-4" style="color: var(--fg-1)">Mon profil</h2>
        <form method="post" action="{{ path('app_settings_profile') }}" data-controller="form-loader">
            <div class="space-y-3">
                <div>
                    <label class="block text-sm font-medium mb-1" style="color: var(--fg-3)">Nom affiché</label>
                    <input type="text" name="display_name" value="{{ app.user.displayName }}"
                           class="input-field" placeholder="Votre nom" required>
                </div>
                <div data-controller="username-check"
                     data-username-check-endpoint-value="{{ path('app_settings_check_username') }}">
                    <label class="block text-sm font-medium mb-1" style="color: var(--fg-3)">Pseudo (@)</label>
                    <div class="relative">
                        <span class="absolute left-4 top-1/2 -translate-y-1/2 text-sm pointer-events-none" style="color: var(--fg-4)">@</span>
                        <input type="text" name="username"
                               value="{{ app.user.username }}"
                               class="input-field pl-7"
                               data-username-check-target="input"
                               data-action="input->username-check#check"
                               minlength="3" maxlength="30"
                               autocomplete="off"
                               placeholder="ton_pseudo">
                    </div>
                    <div data-username-check-target="feedback"></div>
                    <p class="text-xs mt-1" style="color: var(--fg-4)">Lettres minuscules, chiffres et _ uniquement</p>
                </div>
                <div>
                    <label class="block text-sm font-medium mb-1" style="color: var(--fg-3)">Bio</label>
                    <textarea name="bio" rows="3" class="input-field resize-none"
                              placeholder="Une courte description...">{{ app.user.bio }}</textarea>
                </div>
                <button type="submit" class="btn-primary w-full py-3">Enregistrer le profil</button>
            </div>
        </form>
    </div>

    {# ── Appearance ── #}
    <div class="card" data-controller="theme" data-theme-url-value="{{ path('app_settings_theme') }}">
        <h2 class="font-medium mb-1" style="color: var(--fg-1)">Apparence</h2>
        <p class="text-xs mb-3" style="color: var(--fg-3)">« Auto » suit le réglage clair/sombre de ton téléphone.</p>
        <div class="iwt-segmented">
            {% for value, label in {'light': '☀️ Clair', 'dark': '🌙 Sombre', 'auto': '⚙️ Auto'} %}
            <label class="iwt-segmented-option">
                <input type="radio" name="theme" value="{{ value }}"
                       data-action="theme#select" data-theme-theme-param="{{ value }}"
                       {{ app.user.theme == value ? 'checked' : '' }}>
                <span>{{ label }}</span>
            </label>
            {% endfor %}
        </div>
    </div>

    {# ── Push notifications section ── #}
    {% if vapid_public_key %}
    <div class="card">
        <h2 class="font-medium mb-1" style="color: var(--fg-1)">Notifications push</h2>
        <p class="text-xs mb-3" style="color: var(--fg-3)">
            Pour désactiver, va dans Réglages iPhone → Notifications → IWasThere.
        </p>

        <div style="display:flex; align-items:center; justify-content:space-between; gap:1rem;">
            <div style="flex:1; min-width:0;">
                <div style="font-size:.875rem; font-weight:500; color:var(--fg-1)">Activer les notifications</div>
            </div>
            <label style="position:relative; display:inline-flex; align-items:center; cursor:pointer; flex-shrink:0;">
                <input type="checkbox" id="notif-toggle"
                       style="position:absolute; opacity:0; width:0; height:0; pointer-events:none;">
                <span id="notif-track"
                      style="width:48px; height:26px; background:#2c2c2e; border-radius:999px;
                             position:relative; display:block; transition:background .2s;">
                    <span id="notif-thumb"
                          style="position:absolute; top:2px; left:2px; width:22px; height:22px;
                                 background:#888; border-radius:50%;
                                 transition:transform .2s, background .2s;"></span>
                </span>
            </label>
        </div>
    </div>

    <script data-turbo-eval="false">
    (function() {
        const toggle = document.getElementById('notif-toggle');
        const track = document.getElementById('notif-track');
        const thumb = document.getElementById('notif-thumb');
        const publicKey = "{{ vapid_public_key|default('') }}";
        const subscribeUrl = "{{ path('app_subscribe') }}";

        function urlBase64ToUint8Array(b64) {
            const pad = '='.repeat((4 - b64.length % 4) % 4);
            const base64 = (b64 + pad).replace(/\-/g, '+').replace(/_/g, '/');
            const raw = window.atob(base64);
            const out = new Uint8Array(raw.length);
            for (let i = 0; i < raw.length; ++i) out[i] = raw.charCodeAt(i);
            return out;
        }

        function paint(on) {
            if (on) {
                track.style.background = 'rgba(61,220,151,0.30)';
                thumb.style.background = '#3DDC97';
                thumb.style.transform = 'translateX(22px)';
            } else {
                track.style.background = '#2c2c2e';
                thumb.style.background = '#888';
                thumb.style.transform = 'translateX(0)';
            }
        }

        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('/sw.js').catch(() => {});
        }

        if (!publicKey) {
            toggle.disabled = true;
        } else {
            if (Notification.permission === 'granted') {
                toggle.checked = true;
                paint(true);
            } else if (Notification.permission === 'denied') {
                toggle.disabled = true;
            }

            toggle.addEventListener('change', async function() {
                paint(this.checked);
                if (this.checked) {
                    const ok = await subscribeUser();
                    if (!ok) {
                        this.checked = false;
                        paint(false);
                    }
                } else {
                    await unsubscribeUser();
                }
            });
        }

        async function subscribeUser() {
            if (!('serviceWorker' in navigator)) return false;
            try {
                const permission = await Notification.requestPermission();
                if (permission !== 'granted') return false;

                const reg = await navigator.serviceWorker.ready;
                let sub = await reg.pushManager.getSubscription();
                if (!sub) {
                    sub = await reg.pushManager.subscribe({
                        userVisibleOnly: true,
                        applicationServerKey: urlBase64ToUint8Array(publicKey)
                    });
                }

                const response = await fetch(subscribeUrl, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(sub)
                });
                return response.ok;
            } catch (e) {
                console.error('subscribeUser error:', e);
                return false;
            }
        }

        async function unsubscribeUser() {
            try {
                const reg = await navigator.serviceWorker.ready;
                const sub = await reg.pushManager.getSubscription();
                if (sub) await sub.unsubscribe();
            } catch (e) {
                console.error('unsubscribeUser error:', e);
            }
        }
    })();
    </script>
    {% endif %}

    {# ── Notification preferences: one row per NotificationType, grouped ── #}
    <div class="card">
        <h2 class="font-medium mb-1" style="color: var(--fg-1)">Préférences de notifications</h2>
        <p class="text-xs mb-4" style="color: var(--fg-3)">
            Ces réglages ne concernent que les push. Tout reste consultable dans tes notifications.
        </p>
        <form method="post" action="{{ path('app_settings_notifications') }}" data-controller="form-loader">
            {% for group, types in notif_groups %}
            <p class="text-[11px] font-bold uppercase tracking-wider mt-4 mb-2" style="color: var(--fg-4); font-family: var(--font-mono)">{{ group }}</p>
            <div class="space-y-3">
                {% for type in types %}
                {# Une clé absente vaut « activé » : un type ajouté après coup est reçu par défaut #}
                <label class="flex items-start justify-between gap-3 cursor-pointer">
                    <div class="flex-1 min-w-0">
                        <p class="text-sm" style="color: var(--fg-2)">{{ type.icon }} {{ type.label }}</p>
                        <p class="text-xs mt-0.5" style="color: var(--fg-4)">{{ type.description }}</p>
                    </div>
                    <input type="checkbox" name="notif_{{ type.value }}" value="1"
                           class="w-5 h-5 rounded accent-[#3DDC97] flex-shrink-0 mt-0.5"
                           {{ app.user.notifPrefs[type.value] ?? true ? 'checked' : '' }}>
                </label>
                {% endfor %}
            </div>
            {% endfor %}

            <div class="mt-4 pt-4" style="border-top: 1px solid var(--border-subtle)">
                <label class="block text-sm mb-1" style="color: var(--fg-2)">Heure des rappels</label>
                <p class="text-xs mb-2" style="color: var(--fg-4)">Quand partent le rappel du jour J et celui de complétion.</p>
                <input type="time" name="notif_completion_time"
                       value="{{ app.user.notifCompletionTime ?? '08:00' }}"
                       class="input-field w-auto">
            </div>

            <button type="submit" class="btn-primary w-full py-3 mt-4">Sauvegarder</button>
        </form>
    </div>

    {# ── Privacy section ── #}
    <div class="card">
        <h2 class="font-medium mb-1" style="color: var(--fg-1)">Confidentialité</h2>
        <p class="text-sm mb-4" style="color: var(--fg-3)">
            Tes amis voient toujours tous tes événements. Ce réglage ne décide que de ce
            que voient les autres.
        </p>
        <form method="post" action="{{ path('app_settings_privacy') }}" data-controller="form-loader">
            <div class="space-y-4">
                <div>
                    <label class="block text-sm font-medium mb-1.5" style="color: var(--fg-3)">Mon compte</label>
                    <select name="profile_visibility" class="input-field">
                        <option value="private" {{ app.user.profileVisibility == 'private' ? 'selected' : '' }}>🔒 Privé — seuls mes amis voient mes événements</option>
                        <option value="public" {{ app.user.profileVisibility == 'public' ? 'selected' : '' }}>🌍 Public — tout le monde voit mes événements</option>
                    </select>
                </div>
                <button type="submit" class="btn-primary w-full py-3">Sauvegarder</button>
            </div>
        </form>
    </div>

    {# ── Public link section ── #}
    {% set share_url = url('app_public_profile', {username: app.user.username}) %}
    <div class="card">
        <h2 class="font-medium mb-1" style="color: var(--fg-1)">Mon lien</h2>
        <p class="text-sm mb-3" style="color: var(--fg-3)">
            {% if app.user.isPublicProfile %}
                L'adresse de ton profil, à partager où tu veux. Tout le monde peut l'ouvrir,
                même sans compte. Tes notes et tes commentaires n'y figurent jamais.
            {% else %}
                L'adresse de ton profil. Ton compte étant privé, ceux qui ne sont pas tes amis
                y verront un cadenas et pourront te demander en ami.
            {% endif %}
        </p>

        <div data-controller="copy">
            <div class="flex gap-2">
                <input type="text" class="input-field" readonly value="{{ share_url }}"
                       data-copy-target="source" onfocus="this.select()">
                <button type="button" class="btn-secondary px-4 flex-shrink-0"
                        data-action="copy#copy" data-copy-target="button">Copier</button>
            </div>
            <a href="{{ share_url }}" target="_blank" rel="noopener"
               class="inline-block text-sm font-medium mt-3" style="color: var(--positive)">
                Voir la page →
            </a>
        </div>
    </div>

    {# ── Change password section ── #}
    {% if app.user.password %}
    <div class="card">
        <h2 class="font-medium mb-4" style="color: var(--fg-1)">Changer le mot de passe</h2>
        <form method="post" action="{{ path('app_settings_password') }}" data-controller="form-loader">
            <div class="space-y-3">
                <div>
                    <label class="block text-sm font-medium mb-1" style="color: var(--fg-3)">Mot de passe actuel</label>
                    <input type="password" name="current_password" class="input-field" required>
                </div>
                <div>
                    <label class="block text-sm font-medium mb-1" style="color: var(--fg-3)">Nouveau mot de passe</label>
                    <input type="password" name="new_password" class="input-field" minlength="8" required>
                </div>
                <div>
                    <label class="block text-sm font-medium mb-1" style="color: var(--fg-3)">Confirmer le mot de passe</label>
                    <input type="password" name="confirm_password" class="input-field" required>
                </div>
                <button type="submit" class="btn-primary w-full py-3">Changer le mot de passe</button>
            </div>
        </form>
    </div>
    {% endif %}

    {# ── Account info ── #}
    <div class="card" style="background: var(--bg-2)">
        <div class="space-y-2 text-sm">
            <div class="flex justify-between">
                <span style="color: var(--fg-3)">Email</span>
                <span class="font-medium" style="color: var(--fg-1)">{{ app.user.email }}</span>
            </div>
            <div class="flex justify-between">
                <span style="color: var(--fg-3)">Pseudo</span>
                <span class="font-medium" style="color: var(--fg-1)">@{{ app.user.username }}</span>
            </div>
            <div class="flex justify-between">
                <span style="color: var(--fg-3)">Membre depuis</span>
                <span class="font-medium" style="color: var(--fg-1)">{{ app.user.createdAt|date('d/m/Y') }}</span>
            </div>
            {% if app.user.googleId %}
            <div class="flex justify-between">
                <span style="color: var(--fg-3)">Connexion</span>
                <span class="font-medium" style="color: var(--fg-1)">Google</span>
            </div>
            <div class="flex justify-between items-center pt-1" style="border-top: 1px solid var(--border-subtle)">
                <span style="color: var(--fg-3)">Photo de profil</span>
                <a href="{{ path('app_google_refresh_avatar') }}" class="text-xs font-medium" style="color: var(--positive)">
                    Synchroniser depuis Google →
                </a>
            </div>
            {% endif %}
        </div>
    </div>

    {# ── Danger zone ── #}
    <div class="card" style="border: 1px solid rgba(232,155,142,0.3)">
        <h2 class="font-medium mb-2" style="color: var(--negative)">Zone dangereuse</h2>
        <p class="text-sm mb-4" style="color: var(--fg-3)">La suppression de ton compte est irréversible. Toutes tes données seront définitivement perdues.</p>
        <details>
            <summary class="text-sm font-medium cursor-pointer" style="color: var(--negative)">Supprimer mon compte</summary>
            <form method="post" action="{{ path('app_settings_delete_account') }}" class="mt-4">
                <p class="text-sm mb-3" style="color: var(--fg-2)">Tape <strong>SUPPRIMER</strong> pour confirmer :</p>
                <input type="text" name="confirmation" placeholder="SUPPRIMER"
                       class="input-field mb-3" style="border-color: rgba(232,155,142,0.4)" required>
                <button type="submit" class="btn-danger w-full py-3">
                    Supprimer définitivement
                </button>
            </form>
        </details>
    </div>

    {# ── Support section ── #}
    <div class="card">
        <h2 class="font-medium mb-1" style="color: var(--fg-1)">Aide &amp; support</h2>
        <p class="text-sm mb-3" style="color: var(--fg-3)">
            Un bug à signaler, une amélioration à proposer ? Écris-nous.
        </p>
        <a href="mailto:support@iwasthereapp.app" class="btn-secondary w-full py-3 block text-center">
            Contacter le support
        </a>
    </div>

    {# ── Logout ── #}
    <a href="{{ path('app_logout') }}"
       class="block w-full text-center py-3.5 rounded-2xl font-medium transition-colors"
       style="border: 1px solid var(--border-default); color: var(--fg-3)">
        Se déconnecter
    </a>

    {# ── Liens légaux ── #}
    <div class="pb-4 text-center text-xs space-x-3" style="color: var(--fg-4)">
        <a href="{{ path('app_legal_notice') }}" style="color: var(--fg-3)">Mentions légales</a>
        <span>·</span>
        <a href="{{ path('app_privacy') }}" style="color: var(--fg-3)">Confidentialité</a>
    </div>

</div>
{% endblock %}
