{% extends 'admin/layout.html.twig' %}

{% block title %}{{ event.artistName ?? event.tournamentName ?? 'Événement' }}{% endblock %}

{% block body %}
<div class="flex items-center gap-3 mb-6">
    <a href="{{ path('app_admin_events') }}" class="text-sm" style="color: var(--fg-4)">← Retour</a>
    <h1 class="text-2xl font-semibold" style="color: var(--fg-1)">
        {{ event.artistName ?? event.tournamentName ?? 'Événement' }}
    </h1>
    <a href="{{ path('app_admin_event_edit', {id: event.id}) }}"
       class="ml-auto px-4 py-2 rounded-xl text-sm font-medium"
       style="background: var(--bg-2); color: var(--fg-2)">Éditer</a>
</div>

<div class="grid grid-cols-2 gap-6 mb-8">
    <div class="rounded-2xl p-5 space-y-3" style="background: var(--bg-1); border: 1px solid var(--border-subtle)">
        <h2 class="font-semibold text-sm uppercase tracking-wide" style="color: var(--fg-4)">Détails</h2>
        <dl class="space-y-2 text-sm">
            <div class="flex gap-2"><dt style="color: var(--fg-4)">Catégorie</dt><dd style="color: var(--fg-1)">{{ event.category }}</dd></div>
            <div class="flex gap-2"><dt style="color: var(--fg-4)">Type</dt><dd style="color: var(--fg-1)">{{ event.type }}</dd></div>
            <div class="flex gap-2"><dt style="color: var(--fg-4)">Date</dt><dd style="color: var(--fg-1)">{{ event.date|date('d/m/Y') }}</dd></div>
{% if event.teams %}<div class="flex gap-2"><dt style="color: var(--fg-4)">Équipes</dt><dd style="color: var(--fg-1)">{{ event.teams }}</dd></div>{% endif %}
            {% if event.venue %}
            <div class="flex gap-2"><dt style="color: var(--fg-4)">Lieu</dt>
                <dd style="color: var(--fg-1)">{{ event.venue.name }}</dd>
            </div>
            {% endif %}
            <div class="flex gap-2"><dt style="color: var(--fg-4)">Participants</dt><dd class="font-semibold" style="color: var(--positive)">{{ event.participantCount }}</dd></div>
            <div class="flex gap-2"><dt style="color: var(--fg-4)">Créé le</dt><dd style="color: var(--fg-3)">{{ event.createdAt|date('d/m/Y H:i') }}</dd></div>
        </dl>
    </div>

    {% if event.category == 'music' %}
    <div class="rounded-2xl p-5" style="background: var(--bg-1); border: 1px solid var(--border-subtle)">
        <h2 class="font-semibold text-sm uppercase tracking-wide mb-3" style="color: var(--fg-4)">Setlist</h2>
        {% if event.setlist and event.setlist|length > 0 %}
            <p class="text-xs mb-2" style="color: var(--fg-4)">Source : {{ event.setlistSource ?? '?' }} — {{ event.setlist|length }} titres</p>
            <ol class="text-sm space-y-1 max-h-48 overflow-y-auto" style="color: var(--fg-2)">
                {% for song in event.setlist %}
                <li class="flex gap-2"><span style="color: var(--fg-4)">{{ loop.index }}.</span> {{ song }}</li>
                {% endfor %}
            </ol>
        {% else %}
            <p class="text-sm" style="color: var(--fg-4)">Pas de setlist</p>
            {% if event.category == 'music' %}
            <form method="post" action="{{ path('app_admin_event_setlist_import', {id: event.id}) }}" class="mt-3">
                <button class="text-sm font-medium" style="color: #60A5FA">Importer depuis Setlist.fm</button>
            </form>
            {% endif %}
        {% endif %}
    </div>
    {% endif %}
</div>

<h2 class="text-lg font-semibold mb-4" style="color: var(--fg-1)">Participations ({{ participations|length }})</h2>

<div class="rounded-2xl overflow-hidden" style="background: var(--bg-1); border: 1px solid var(--border-subtle)">
    <table class="w-full text-sm">
        <thead style="background: var(--bg-2); color: var(--fg-4)">
            <tr>
                <th class="px-5 py-3 text-left text-xs uppercase tracking-wide">Utilisateur</th>
                <th class="px-5 py-3 text-left text-xs uppercase tracking-wide">Statut</th>
                <th class="px-5 py-3 text-left text-xs uppercase tracking-wide">Note</th>
                <th class="px-5 py-3 text-left text-xs uppercase tracking-wide">Commentaire</th>
                <th class="px-5 py-3 text-left text-xs uppercase tracking-wide">Visibilité</th>
                <th class="px-5 py-3 text-left text-xs uppercase tracking-wide">Date</th>
                <th class="px-5 py-3"></th>
            </tr>
        </thead>
        <tbody>
            {% for p in participations %}
            <tr style="border-top: 1px solid var(--border-subtle)">
                <td class="px-5 py-3">
                    <a href="{{ path('app_admin_user_show', {id: p.user.id}) }}"
                       class="font-medium" style="color: var(--positive)">{{ p.user.displayName }}</a>
                    <div class="text-xs" style="color: var(--fg-4)">@{{ p.user.username }}</div>
                </td>
                <td class="px-5 py-3">
                    <span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium"
                          style="{% if p.status == 'past' %}background: var(--positive-soft); color: var(--positive)
                          {% else %}background: rgba(96,165,250,0.1); color: #60A5FA{% endif %}">
                        {{ p.status }}
                    </span>
                </td>
                <td class="px-5 py-3 text-xs" style="color: var(--fg-2)">
                    {% if p.rating %}{% for i in 1..p.rating %}★{% endfor %}{% else %}—{% endif %}
                </td>
                <td class="px-5 py-3 text-xs max-w-xs truncate" style="color: var(--fg-3)">
                    {{ p.comment ?? '—' }}
                </td>
                <td class="px-5 py-3 text-xs" style="color: var(--fg-4)">{{ p.visibility }}</td>
                <td class="px-5 py-3 text-xs" style="color: var(--fg-4)">{{ p.createdAt|date('d/m/Y') }}</td>
                <td class="px-5 py-3 text-right">
                    <form method="post"
                          action="{{ path('app_admin_participation_delete', {id: event.id, pid: p.id}) }}"
                          onsubmit="return confirm('Supprimer cette participation ?')">
                        <button class="text-xs" style="color: var(--negative)">Supprimer</button>
                    </form>
                </td>
            </tr>
            {% else %}
            <tr>
                <td colspan="7" class="px-5 py-8 text-center text-sm" style="color: var(--fg-4)">Aucune participation</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
