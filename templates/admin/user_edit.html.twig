{% extends 'admin/layout.html.twig' %}

{% block title %}Éditer {{ profile_user.displayName }}{% endblock %}

{% block body %}
<div class="max-w-xl">
    <div class="flex items-center gap-3 mb-6">
        <a href="{{ path('app_admin_user_show', {id: profile_user.id}) }}"
           class="text-sm" style="color: var(--fg-4)">← Retour</a>
        <h1 class="text-2xl font-semibold" style="color: var(--fg-1)">Éditer {{ profile_user.displayName }}</h1>
    </div>

    <div class="rounded-2xl p-6 space-y-5" style="background: var(--bg-1); border: 1px solid var(--border-subtle)">
        <form method="post" action="{{ path('app_admin_user_edit', {id: profile_user.id}) }}" class="space-y-5">

            <div>
                <label class="block text-xs font-medium mb-1.5 uppercase tracking-wide" style="color: var(--fg-4)">Nom affiché</label>
                <input type="text" name="display_name" class="input-field" value="{{ profile_user.displayName }}" required>
            </div>

            <div>
                <label class="block text-xs font-medium mb-1.5 uppercase tracking-wide" style="color: var(--fg-4)">Email</label>
                <input type="email" name="email" class="input-field" value="{{ profile_user.email }}" required>
            </div>

            <div>
                <label class="block text-xs font-medium mb-1.5 uppercase tracking-wide" style="color: var(--fg-4)">Bio</label>
                <textarea name="bio" rows="3" class="input-field resize-none">{{ profile_user.bio }}</textarea>
            </div>

            <div>
                <label class="block text-xs font-medium mb-1.5 uppercase tracking-wide" style="color: var(--fg-4)">Rôle</label>
                <select name="role" class="input-field">
                    <option value="user" {{ profile_user.role == 'user' ? 'selected' : '' }}>Utilisateur</option>
                    <option value="superAdmin" {{ profile_user.role == 'superAdmin' ? 'selected' : '' }}>Super Admin</option>
                </select>
            </div>

            <div class="flex gap-3 pt-2">
                <a href="{{ path('app_admin_user_show', {id: profile_user.id}) }}"
                   class="flex-1 py-2.5 text-sm text-center rounded-xl font-medium"
                   style="background: var(--bg-2); color: var(--fg-3)">Annuler</a>
                <button type="submit" class="flex-1 btn-primary py-2.5">Sauvegarder</button>
            </div>
        </form>
    </div>
</div>
{% endblock %}
