{% extends 'admin/layout.html.twig' %}

{% block title %}Lieux{% endblock %}

{% block body %}
<div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-semibold" style="color: var(--fg-1); letter-spacing: -0.01em">Lieux</h1>
    <form method="get" class="flex gap-2">
        <input type="search" name="q" value="{{ q }}"
               class="input-field w-64"
               placeholder="Nom, ville...">
        <button class="btn-primary px-4 py-2">Chercher</button>
    </form>
</div>

<div class="rounded-2xl overflow-hidden" style="background: var(--bg-1); border: 1px solid var(--border-subtle)">
    <table class="w-full text-sm">
        <thead style="background: var(--bg-2); color: var(--fg-4)">
            <tr>
                <th class="px-5 py-3 text-left text-xs uppercase tracking-wide">Salle / Stade</th>
                <th class="px-5 py-3 text-left text-xs uppercase tracking-wide">Adresse</th>
                <th class="px-5 py-3 text-left text-xs uppercase tracking-wide">Ville</th>
                <th class="px-5 py-3 text-left text-xs uppercase tracking-wide">Pays</th>
                <th class="px-5 py-3 text-left text-xs uppercase tracking-wide">Type</th>
                <th class="px-5 py-3 text-right text-xs uppercase tracking-wide">Capacité</th>
                <th class="px-5 py-3"></th>
            </tr>
        </thead>
        <tbody>
            {% for venue in venues %}
            <tr style="border-top: 1px solid var(--border-subtle)">
                <td class="px-5 py-3 font-medium" style="color: var(--fg-1)">{{ venue.name }}</td>
                <td class="px-5 py-3 text-xs" style="color: var(--fg-4)">{{ venue.address }}</td>
                <td class="px-5 py-3" style="color: var(--fg-2)">{{ venue.city }}</td>
                <td class="px-5 py-3" style="color: var(--fg-3)">{{ venue.country }}</td>
                <td class="px-5 py-3 text-xs" style="color: var(--fg-4)">{{ venue.venueType ?? '—' }}</td>
                <td class="px-5 py-3 text-xs text-right" style="color: var(--fg-4)">
                    {{ venue.capacity ? venue.capacity|number_format(0, ',', ' ') : '—' }}
                </td>
                <td class="px-5 py-3 text-right">
                    <div class="flex items-center justify-end gap-3">
                        <a href="{{ path('app_admin_venue_edit', {id: venue.id}) }}"
                           class="text-xs font-medium" style="color: #60A5FA">Éditer</a>
                        <form method="post" action="{{ path('app_admin_venue_delete', {id: venue.id}) }}"
                              onsubmit="return confirm('Supprimer le lieu {{ venue.name|escape('js') }} ?')">
                            <button class="text-xs" style="color: var(--negative)">Supprimer</button>
                        </form>
                    </div>
                </td>
            </tr>
            {% else %}
            <tr>
                <td colspan="7" class="px-5 py-10 text-center" style="color: var(--fg-4)">
                    {% if q %}Aucun lieu trouvé pour "{{ q }}"{% else %}Aucun lieu enregistré{% endif %}
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
