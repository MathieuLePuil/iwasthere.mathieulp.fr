{% extends 'admin/layout.html.twig' %}

{% block title %}Éditer {{ event.artistName ?? event.tournamentName ?? 'Événement' }}{% endblock %}

{% block body %}
<div class="max-w-xl">
    <div class="flex items-center gap-3 mb-6">
        <a href="{{ path('app_admin_event_show', {id: event.id}) }}"
           class="text-sm" style="color: var(--fg-4)">← Retour</a>
        <h1 class="text-2xl font-semibold" style="color: var(--fg-1)">
            Éditer {{ event.artistName ?? event.tournamentName ?? 'Événement' }}
        </h1>
    </div>

    <div class="rounded-2xl p-6 space-y-5" style="background: var(--bg-1); border: 1px solid var(--border-subtle)">
        <form method="post" action="{{ path('app_admin_event_edit', {id: event.id}) }}" class="space-y-5">

            <div>
                <label class="block text-xs font-medium mb-1.5 uppercase tracking-wide" style="color: var(--fg-4)">Type</label>
                <input type="text" name="type" class="input-field" value="{{ event.type }}" required>
                <p class="text-xs mt-1" style="color: var(--fg-4)">concert, festival, football, rugby, tennis, basket…</p>
            </div>

            {% if event.category == 'music' %}
            <div>
                <label class="block text-xs font-medium mb-1.5 uppercase tracking-wide" style="color: var(--fg-4)">Artiste</label>
                <input type="text" name="artist_name" class="input-field" value="{{ event.artistName ?? '' }}">
            </div>
            {% else %}
            <div>
                <label class="block text-xs font-medium mb-1.5 uppercase tracking-wide" style="color: var(--fg-4)">Tournoi / Compétition</label>
                <input type="text" name="tournament_name" class="input-field" value="{{ event.tournamentName ?? '' }}">
            </div>
            <div>
                <label class="block text-xs font-medium mb-1.5 uppercase tracking-wide" style="color: var(--fg-4)">Équipes (ex : PSG vs OM)</label>
                <input type="text" name="teams" class="input-field" value="{{ event.teams ?? '' }}">
            </div>
            {% endif %}

            <div>
                <label class="block text-xs font-medium mb-1.5 uppercase tracking-wide" style="color: var(--fg-4)">Date</label>
                <input type="date" name="date" class="input-field" value="{{ event.date|date('Y-m-d') }}" required>
            </div>

            <div>
                <label class="block text-xs font-medium mb-1.5 uppercase tracking-wide" style="color: var(--fg-4)">Lieu</label>
                <select name="venue_id" class="input-field">
                    <option value="">— Aucun lieu —</option>
                    {% for venue in venues %}
                    <option value="{{ venue.id }}" {{ event.venue and event.venue.id == venue.id ? 'selected' : '' }}>
                        {{ venue.name }} — {{ venue.city }}
                    </option>
                    {% endfor %}
                </select>
            </div>

            <div class="flex gap-3 pt-2">
                <a href="{{ path('app_admin_event_show', {id: event.id}) }}"
                   class="flex-1 py-2.5 text-sm text-center rounded-xl font-medium"
                   style="background: var(--bg-2); color: var(--fg-3)">Annuler</a>
                <button type="submit" class="flex-1 btn-primary py-2.5">Sauvegarder</button>
            </div>
        </form>
    </div>
</div>
{% endblock %}
